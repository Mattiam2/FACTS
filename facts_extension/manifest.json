{
  "manifest_version": 3,
  "name": "FACTS",
  "version": "1.0",
  "description": "FACTS lets you see news credibility and authenticity data to provide total transparency on what you read online.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open FACTS"
  },
  "permissions": ["activeTab", "tabs"],
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "180": "icons/favicon-180x180.png"
  },
  "host_permissions": [
    "http://localhost:8001/*"
  ]
}